# =====================================================================
# req-optimizer-mcp .env 模板
#
# 用法：复制为 .env.local 并按需修改
#   cp .env.example .env.local
#
# 注意：MCP server 启动时拿不到 IDE 的环境变量，所以**必须**在本目录
# 配置 .env.local（项目根目录），server 启动时由 dotenv 加载。
# =====================================================================

# ===== Embedding（RAG 用，必填）=====
EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxx
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2

# ===== 知识库路径 =====
# 复用 req-optimizer-web 的 ingest 结果。
# 相对路径以本项目（req-optimizer-mcp/）为基准。
KNOWLEDGE_DIR=../req-optimizer-web/knowledge
KNOWLEDGE_INDEX=../req-optimizer-web/knowledge.index.json
